# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT (direct Airtable access — PAT exposed in client bundle)
# ---------------------------------------------------------------------------
# Airtable Personal Access Token (https://airtable.com/create/tokens)
VITE_AIRTABLE_PAT=patYourTokenHere
# Airtable Base ID (found in API docs or base URL)
VITE_AIRTABLE_BASE_ID=appYourBaseIdHere
# Airtable Table Name
VITE_AIRTABLE_TABLE_NAME=Kitchen Inventory

# ---------------------------------------------------------------------------
# PRODUCTION (Netlify serverless proxy — PAT stays server-side)
# ---------------------------------------------------------------------------
# On Netlify, set these as Environment Variables in Site → Environment
# (no VITE_ prefix — they are read by the serverless function, not the browser):
#   AIRTABLE_PAT=patYourTokenHere
#   AIRTABLE_BASE_ID=appYourBaseIdHere
#   AIRTABLE_TABLE_NAME=Kitchen Inventory
#
# When VITE_AIRTABLE_PAT is missing from the build, the app automatically
# routes API calls through /.netlify/functions/airtable.

# ---------------------------------------------------------------------------
# Feature flags
# ---------------------------------------------------------------------------
# Set to true to prevent airtable from getting hammered with fetch requests while developing
VITE_SAMPLE_DATA=false
# Set to true to enable server-side sorting/filtering via Airtable query params (default: false, uses client-side)
VITE_SERVER_FILTER=false
# Set to true to simulate occasional (33% Chance) API errors for testing error handling in the UI
VITE_SIMULATE_ERRORS=false