# Airtable Personal Access Token (https://airtable.com/create/tokens)
VITE_AIRTABLE_PAT=patYourTokenHere
# Airtable Base ID (found in API docs or base URL)
VITE_AIRTABLE_BASE_ID=appYourBaseIdHere
# Airtable Table Name
VITE_AIRTABLE_TABLE_NAME=Kitchen Inventory
# Set to true to prevent airtable from getting hammered with fetch requests while developing
VITE_SAMPLE_DATA=false